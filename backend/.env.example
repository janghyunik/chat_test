# FastAPI 기본 설정
APP_NAME=chat_test_backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
SESSION_EXPIRE_HOURS=12

# 로그인용 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_EMAIL=admin@example.com

# LLM / PostgreSQL
LLM_MODEL=gemma3:4b
EMBEDDING_MODEL=granite-embedding:278m
PG_CONN_STR=host=localhost dbname=vectorDB user=postgres password=1541

# 고급 RAG / 플레이북 / 검증 설정
RAG_DENSE_TOP_K_PER_QUERY=6
RAG_KEYWORD_TOP_K=10
RAG_FIRST_PASS_KEEP=18
RAG_FINAL_CONTEXT_DOCS=6
ENABLE_RAG_VERIFIER=1

# 채팅 메모리 PostgreSQL 저장 (PG_CONN_STR 동일 DB 사용)
CHAT_STORAGE_BACKEND=postgres

# Monitoring / observability
# 별도 모니터링 웹은 동일 PostgreSQL의 monitoring_* 테이블을 조회합니다.
MONITORING_ACTIVE_WINDOW_MINUTES=5
