# FastAPI 기본 설정
APP_NAME=chat_test_backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
SESSION_EXPIRE_HOURS=12

# 로그인용 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_EMAIL=admin@example.com

# LLM / PostgreSQL
LLM_MODEL=llama3-ko
EMBEDDING_MODEL=granite-embedding:278m
PG_CONN_STR=host=localhost dbname=vectorDB user=postgres password=1541
